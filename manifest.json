{
  "manifest_version": 2,
  "name": "SPH Gmail - Superhuman AI for Gmail",
  "version": "1.0.0",
  "description": "Superhuman-style AI capabilities for Gmail: triage, compose, summaries, and smart replies. Works in Zen Browser and Firefox.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": ["*://mail.google.com/*"],
      "js": [
        "src/providers/provider-base.js",
        "src/providers/openai.js",
        "src/providers/anthropic.js",
        "src/providers/gemini.js",
        "src/providers/ollama.js",
        "src/providers/provider-factory.js",
        "src/features/triage.js",
        "src/features/compose.js",
        "src/features/summarize.js",
        "src/features/smart-reply.js",
        "src/content/gmail-dom.js",
        "src/content/main.js"
      ],
      "css": ["src/ui/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["src/background/background.js"]
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "sph-gmail@superhuman-ai",
      "strict_min_version": "109.0"
    }
  }
}
